<script>
// ═══════════════════════════════════════════════
// ZONA HORARIA
// ═══════════════════════════════════════════════
const CHILE_OFFSET = -4;
const CHILE_UTC_HOUR = 10 - CHILE_OFFSET; // 14 UTC

const COUNTRY_DATA = {
    'Chile':     { offset: -4, flag: '🇨🇱' },
    'Argentina': { offset: -3, flag: '🇦🇷' },
    'Bolivia':   { offset: -4, flag: '🇧🇴' },
    'Colombia':  { offset: -5, flag: '🇨🇴' },
    'Ecuador':   { offset: -5, flag: '🇪🇨' },
    'Guatemala': { offset: -6, flag: '🇬🇹' },
    'México':    { offset: -6, flag: '🇲🇽' },
    'Perú':      { offset: -5, flag: '🇵🇪' },
};

function formatHour(utcHour, offset) {
    let h = utcHour + offset;
    if (h < 0) h += 24;
    if (h >= 24) h -= 24;
    const suffix = h >= 12 ? 'PM' : 'AM';
    const d = h > 12 ? h - 12 : (h === 0 ? 12 : h);
    return `${d}:00 ${suffix}`;
}

function showLocalBlock(flag, name, timeStr) {
    document.getElementById('local-country').textContent = flag + ' ' + name;
    document.getElementById('local-time').textContent = timeStr;
    document.getElementById('local-time-block').style.display = 'block';
    document.getElementById('time-sep').style.display = 'block';
}

(function detectTZ() {
    try {
        const tz = Intl.DateTimeFormat().resolvedOptions().timeZone;
        const tzMap = {
            'America/Argentina/Buenos_Aires': { offset: -3, flag: '🇦🇷', name: 'Argentina' },
            'America/La_Paz':    { offset: -4, flag: '🇧🇴', name: 'Bolivia' },
            'America/Bogota':    { offset: -5, flag: '🇨🇴', name: 'Colombia' },
            'America/Guayaquil': { offset: -5, flag: '🇪🇨', name: 'Ecuador' },
            'America/Guatemala': { offset: -6, flag: '🇬🇹', name: 'Guatemala' },
            'America/Mexico_City': { offset: -6, flag: '🇲🇽', name: 'México' },
            'America/Lima':      { offset: -5, flag: '🇵🇪', name: 'Perú' },
            'America/Caracas':   { offset: -4, flag: '🇻🇪', name: 'Venezuela' },
            'America/Montevideo':{ offset: -3, flag: '🇺🇾', name: 'Uruguay' },
            'America/Asuncion':  { offset: -4, flag: '🇵🇾', name: 'Paraguay' },
            'America/Panama':    { offset: -5, flag: '🇵🇦', name: 'Panamá' },
            'America/Costa_Rica':{ offset: -6, flag: '🇨🇷', name: 'Costa Rica' },
            'America/Tegucigalpa':{ offset: -6, flag: '🇭🇳', name: 'Honduras' },
            'America/Managua':   { offset: -6, flag: '🇳🇮', name: 'Nicaragua' },
            'America/El_Salvador':{ offset: -6, flag: '🇸🇻', name: 'El Salvador' },
        };
        const loc = tzMap[tz];
        if (loc) showLocalBlock(loc.flag, loc.name, formatHour(CHILE_UTC_HOUR, loc.offset));
    } catch(e) {}
})();

function updateLocalTime() {
    const val = document.getElementById('pais').value;
    if (!val || !COUNTRY_DATA[val] || val === 'Chile') {
        document.getElementById('local-time-block').style.display = 'none';
        document.getElementById('time-sep').style.display = 'none';
        return;
    }
    const d = COUNTRY_DATA[val];
    showLocalBlock(d.flag, val, formatHour(CHILE_UTC_HOUR, d.offset));
}

// ═══════════════════════════════════════════════
// MISMO PAGADOR
// ═══════════════════════════════════════════════
function togglePagador() {
    const checked = document.getElementById('mismo-pagador').checked;
    const campos = ['empresa', 'rut-empresa', 'direccion', 'contacto-nombre', 'contacto-email'];

    if (checked) {
        document.getElementById('empresa').value        = document.getElementById('nombre').value;
        document.getElementById('rut-empresa').value    = document.getElementById('rut').value;
        document.getElementById('direccion').value      = '';
        document.getElementById('contacto-nombre').value = document.getElementById('nombre').value;
        document.getElementById('contacto-email').value  = document.getElementById('email').value;
        document.getElementById('lbl-factura').textContent = 'Datos del participante (como figura en la factura)';
        campos.forEach(id => document.getElementById(id).disabled = true);
    } else {
        campos.forEach(id => {
            document.getElementById(id).disabled = false;
            document.getElementById(id).value = '';
        });
        document.getElementById('lbl-factura').textContent = 'Empresa o persona que recibirá la factura';
    }
}

// ═══════════════════════════════════════════════
// SELECCIÓN DE CURSO
// ═══════════════════════════════════════════════
let cursoSeleccionado = null;
const CURSOS = {
    1: 'Diseño e Implementación de Tecnologías para la Detección de Incendios basado en Estándares Internacionales',
    2: 'Diseño e Implementación de Sistemas de Notificación de Incendios y Tecnologías Especiales para la Detección basado en Estándares Internacionales',
};

function selectCourse(n) {
    cursoSeleccionado = n;
    document.querySelectorAll('.course-card').forEach(c => c.classList.remove('selected'));
    document.getElementById('card-' + n).classList.add('selected');
}

// ═══════════════════════════════════════════════
// VALIDACIÓN
// ═══════════════════════════════════════════════
const FIELDS = [
    { id: 'nombre',          err: 'err-nombre' },
    { id: 'rut',             err: 'err-rut' },
    { id: 'email',           err: 'err-email' },
    { id: 'telefono',        err: 'err-telefono' },
    { id: 'cargo',           err: 'err-cargo' },
    { id: 'pais',            err: 'err-pais' },
    { id: 'empresa',         err: 'err-empresa' },
    { id: 'contacto-nombre', err: 'err-contacto-nombre' },
    { id: 'contacto-email',  err: 'err-contacto-email' },
];

function validate() {
    let ok = true;
    FIELDS.forEach(f => {
        const el = document.getElementById(f.id);
        const err = document.getElementById(f.err);
        if (!el || el.disabled) return;
        if (!el.value.trim()) {
            el.classList.add('error');
            err.textContent = 'Campo requerido';
            ok = false;
        } else {
            el.classList.remove('error');
            err.textContent = '';
        }
    });
    if (!cursoSeleccionado) { alert('Por favor selecciona un curso.'); ok = false; }
    if (!document.getElementById('terminos').checked) { alert('Debes aceptar la Política de Privacidad para continuar.'); ok = false; }
    return ok;
}

// ═══════════════════════════════════════════════
// ENVÍO A GOOGLE SHEETS
// ═══════════════════════════════════════════════
// ⚠️ Reemplazar con la URL del Google Apps Script desplegado
const SCRIPT_URL = 'TU_SCRIPT_URL_AQUI';

function enviarFormulario() {
    if (!validate()) return;
    const btn = document.getElementById('btn-submit');
    btn.disabled = true;
    btn.textContent = 'Enviando...';

    const email = document.getElementById('email').value.trim();
    const pais = document.getElementById('pais').value;
    const localTimeStr = COUNTRY_DATA[pais] ? formatHour(CHILE_UTC_HOUR, COUNTRY_DATA[pais].offset) : 'N/A';
    const mismoPagador = document.getElementById('mismo-pagador').checked;

    const payload = {
        timestamp:        new Date().toLocaleString('es-CL', { timeZone: 'America/Santiago' }),
        curso:            CURSOS[cursoSeleccionado],
        fechas:           '4, 5, 6 y 7 de mayo 2026',
        horario_chile:    '10:00 AM',
        horario_local:    localTimeStr,
        nombre:           document.getElementById('nombre').value.trim(),
        rut:              document.getElementById('rut').value.trim(),
        email:            email,
        telefono:         document.getElementById('telefono').value.trim(),
        cargo:            document.getElementById('cargo').value.trim(),
        pais:             pais,
        mismo_pagador:    mismoPagador ? 'Sí' : 'No',
        empresa:          document.getElementById('empresa').value.trim(),
        rut_empresa:      document.getElementById('rut-empresa').value.trim(),
        direccion:        document.getElementById('direccion').value.trim(),
        contacto_nombre:  document.getElementById('contacto-nombre').value.trim(),
        contacto_email:   document.getElementById('contacto-email').value.trim(),
        observaciones:    document.getElementById('observaciones').value.trim(),
        precio_neto:      'USD 247.50',
        iva:              '19%',
        precio_total:     'USD 294.53',
        estado_pago:      'Pendiente',
        pago_confirmado:  'No',
        informado:        'No',
        datos_conexion:   'No enviados',
        certificado:      'No',
    };

    fetch(SCRIPT_URL, {
        method: 'POST',
        mode: 'no-cors',
        headers: { 'Content-Type': 'application/json' },
        body: JSON.stringify(payload),
    })
    .then(() => mostrarExito(email))
    .catch(() => mostrarExito(email));
}

function mostrarExito(email) {
    ['lbl-curso','course-section','form-participante','form-facturacion','form-obs','submit-card'].forEach(id => {
        const el = document.getElementById(id);
        if (el) el.style.display = 'none';
    });
    document.getElementById('email-confirm').textContent = email;
    document.getElementById('success-screen').classList.add('visible');
    window.scrollTo({ top: 0, behavior: 'smooth' });
}
</script>

